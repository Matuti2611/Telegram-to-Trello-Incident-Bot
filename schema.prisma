generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClienteUbicacion {
  id        Int    @id @default(autoincrement())
  direccion String @unique
  clienteId String
}
